{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "NITRO_PRESET": "vercel"
    }
  },
  "buildCommand": "NITRO_PRESET=vercel vite build",
  "outputDirectory": ".vercel/output",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
